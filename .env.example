# Copy to .env. With nothing set, every service runs fully offline on mocks.

# AETHERIS_ENV=production
# AETHERIS_LOG_JSON=true

# Event bus: memory | redis | kafka
# AETHERIS_BUS=redis
# REDIS_URL=redis://localhost:6379
# KAFKA_BROKERS=localhost:9092

# Vision detector: mock | triton
# AETHERIS_DETECTOR=triton
# TRITON_URL=localhost:8001

# LLM egress: mock | ollama
# AETHERIS_LLM=ollama
# OLLAMA_URL=http://localhost:11434

# Data layer
# DATABASE_URL=postgresql://postgres:aetheris@localhost:5432/aetheris

# Thresholds
# AETHERIS_MIN_CONF=0.5
# AETHERIS_PSI=0.2
# AETHERIS_RETRAIN=0.25
